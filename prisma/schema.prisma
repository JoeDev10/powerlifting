generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  name         String?
  email        String            @unique
  password     String
  createdAt    DateTime          @default(now())
  sessions     TrainingSession[]
  exercises    Exercise[]
  templates    Template[]
  bodyWeights  BodyWeight[]
  goals        Goal[]
  blocks       Block[]
  competitions Competition[]
}

model Block {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phase     String
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Competition {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  date        DateTime
  weightClass Float?
  squat       Float?
  bench       Float?
  deadlift    Float?
  total       Float?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Exercise {
  id           String        @id @default(cuid())
  name         String
  category     String
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets         Set[]
  templateSets TemplateSet[]
  goals        Goal[]

  @@index([userId])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise  @relation(fields: [exerciseId], references: [id])
  targetWeight Float
  targetDate   DateTime?
  startWeight  Float?
  achievedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Template {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime      @default(now())
  sets      TemplateSet[]

  @@index([userId])
}

model TemplateSet {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  weight     Float
  reps       Int
  rpe        Float?
  order      Int
}

model BodyWeight {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight Float
  date   DateTime @default(now())
  notes  String?

  @@index([userId])
}

model TrainingSession {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @default(now())
  notes  String?
  sets   Set[]
}

model Set {
  id         String          @id @default(cuid())
  sessionId  String
  session    TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])
  weight     Float
  reps       Int
  rpe        Float?
  order      Int
}
